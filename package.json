{
  "name": "@lychee-technology/ltbase-controlplane-ui",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.21.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:release-artifact": "pnpm run build && node ./scripts/package-release-artifact.mjs",
    "preview": "vite preview",
    "render-runtime-config": "node ./scripts/render-runtime-config.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.8",
    "@vitejs/plugin-react": "^4.3.4",
    "firebase": "^11.7.1",
    "json-schema-editor-visual": "github:Lychee-Technology/json-schema-editor-visual",
    "lucide-react": "^0.469.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.13.1",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.3",
    "vite": "^5.4.14",
    "vitest": "^2.1.8"
  }
}
